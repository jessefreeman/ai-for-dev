# Personal source files (raw inputs — not versioned)
raw/**/*.md
raw/**/*.pdf
raw/**/*.html

# Exceptions — LLM-generated output inside raw/ that should be versioned
!raw/memories/
!raw/memories/*.md

# Obsidian machine-specific state
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Build artifacts
node_modules/
public/

# OS / editor
.DS_Store
.smbdelete*
.env
*.log
.vscode/
.trash/
.obsidian/graph.json
